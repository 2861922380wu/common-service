# 应用配置
NODE_ENV=development
PORT=3000

# CORS 配置（多个域名用逗号分隔，可选）
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# JWT 配置（与管理后台使用相同的 secret）
# 注意：JWT Secret 至少需要 32 个字符
JWT_SECRET=this_is_a_test_secret_key_at_least_32_chars_long_for_testing

# 七牛云配置
QINIU_ACCESS_KEY=your_access_key
QINIU_SECRET_KEY=your_secret_key
QINIU_BUCKET=your_bucket_name
QINIU_DOMAIN=https://your-domain.com
# 区域: z0(华东), z1(华北), z2(华南), na0(北美), as0(东南亚)
QINIU_ZONE=z2
